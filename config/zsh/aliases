killport() {
    if [ -z "$1" ]; then
        echo "Usage: killport <port>"
        return 1
    fi
    local pid=$(lsof -ti:$1)
    if [ -z "$pid" ]; then
        echo "No process found on port $1"
        return 1
    fi
    echo "Killing process $pid on port $1"
    kill $pid
}
scripts() {
	jq .scripts package.json
}
alias installapk='adb install -r'
killapp() {
    if [ -z "$1" ]; then
        echo "Usage: killapp <app>"
        return 1
    fi
    pkill -f "${1}_debug"
    sleep 0.5
    if ! pgrep -f "$1" > /dev/null; then
        echo "killed"
    fi
}
